# =============================================================================
# SmartStudy — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Google Cloud Platform ---------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCS_BUCKET_NAME=smartstudy-pdfs

# --- MongoDB Atlas -----------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=smartstudy
MONGODB_COLLECTION=context
MONGODB_CHAT_HISTORY_COLLECTION=chat_history
MONGODB_VECTOR_INDEX_NAME=vector_index

# --- Vertex AI ---------------------------------------------------------------
VERTEX_AI_EMBEDDING_MODEL=text-embedding-005
VERTEX_AI_LLM_MODEL=gemini-2.5-flash

# --- Chat API (for Streamlit to reach the backend) --------------------------
CHAT_API_URL=http://localhost:8080

# --- Optional upload tuning --------------------------------------------------
GCS_UPLOAD_PREFIX=uploads
MAX_UPLOAD_MB=25
UPLOAD_TIMEOUT_SECONDS=180
STATUS_POLL_INTERVAL_SECONDS=4
STATUS_REQUEST_TIMEOUT_SECONDS=15
